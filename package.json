{
  "name": "my-monorepo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=@my-app/backend",
    "db:seed": "npm run db:seed --workspace=@my-app/backend",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "license": "ISC",
  "dependencies": {
    "pg": "^8.20.0"
  }
}
